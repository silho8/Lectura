# Application Configuration
NODE_ENV=development
PORT=8080

# Database Configuration (Development)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=lectura_dev
DB_USER=root
DB_PASS=password

# JWT Configuration
JWT_SECRET=a_very_strong_and_long_secret_key
JWT_EXPIRES_IN=7d

# File Upload Configuration
MAX_UPLOAD_SIZE_BYTES=20971520 # 20 MB

# Email Configuration (Optional)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# OCR Configuration (Disabled by default)
OCR_ENABLED=false
